# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Environment ────────────────────────────────────────────────────────────────
APP_ENV=development

# ── Google Cloud ───────────────────────────────────────────────────────────────
# Your GCP / Firebase project ID (same value in both)
GOOGLE_CLOUD_PROJECT=your-project-id

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate a strong random key: openssl rand -base64 32
JWT_SECRET=replace-with-a-strong-random-secret

# Note: GOOGLE_CLIENT_ID is no longer needed by the backend.
# Firebase Admin SDK verifies ID tokens using Application Default Credentials.
# The Client ID is only required in the frontend (.env.local).

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
ALLOWED_ORIGINS=http://localhost:5173

# ── Firestore emulator (optional) ──────────────────────────────────────────────
# Uncomment to use the local Firestore emulator instead of the real database.
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8787
